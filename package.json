    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/node": "20.17.9",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "fast-check": "^4.3.0",
    "husky": "^9.1.7",
