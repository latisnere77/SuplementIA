{
  "name": "suplementia",
  "version": "1.0.0",
  "private": true,
  "description": "SuplementIA - Evidence-based health supplement recommendations",
  "scripts": {
    "dev": "next dev",
    "build": "AWS_SDK_JS_NODE_VERSION_SUPPORT_WARNING_DISABLED=true next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "next typegen && tsc --noEmit --incremental false",
    "test": "AWS_SDK_JS_NODE_VERSION_SUPPORT_WARNING_DISABLED=true jest --silent",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "validate": "npm run type-check && npm run build && npm test -- --passWithNoTests",
    "smoke:production:portal": "node scripts/portal-production-smoke.mjs",
    "gsd:invariants": "node scripts/gsd/invariant-ratchet.mjs",
    "gsd:offline-certify": "node scripts/gsd/offline-certify.mjs",
    "gsd:done": "node scripts/gsd/done-oracle.mjs",
    "gsd:digest": "node scripts/gsd/digest.mjs",
    "predeploy": "npm run validate",
    "deploy": "git push origin main",
    "prepare": "husky || true",
    "migrate": "tsx infrastructure/migrations/run-migrations.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.946.0",
